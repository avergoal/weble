{
  "name": "weble",
  "version": "1.0.81",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --ssl --port 4256 ",
    "android": "sudo ng build --prod --aot && sudo  touch ./www/cordova.js && cordova build android",
    "ios": "sudo ng build --prod --aot && sudo  touch ./www/cordova.js && sudo cordova build ios",
    "ios2": "ng build --prod --aot && touch ./www/cordova.js && cordova build ios",
    "build": "ng build",
    "build2": "sudo ng build --prod --aot && sudo  touch ./www/cordova.js && cordova build android --release",
    "step0": "keytool -genkey -v -keystore my.keystore -alias weble -keyalg RSA -keysize 2048 -validity 10000",
    "step1": "jarsigner -verbose -keystore ./my.keystore ./platforms/android/app/build/outputs/apk/release/app-release-unsigned.apk weble ",
    "step2": "zipalign -v 4 ./platforms/android/app/build/outputs/apk/release/app-release-unsigned.apk ./platforms/android/app/build/outputs/apk/release/app-release-unsigned002.apk",
    "step3": " jarsigner -verify -verbose ./platforms/android/app/build/outputs/apk/release/app-release-unsigned002.apk",
    "test": "ng test",
    "lint": "ng lint",
    "extract": "ng2-translate-extract --dir ./src --output ./src/assets/i18n/ru.json --clean --sort --format namespaced-json && ng2-translate-extract --dir ./src --output ./src/assets/i18n/en.json --clean --sort --format namespaced-json && ng2-translate-extract --dir ./src --output ./src/assets/i18n/de.json --clean --sort --format namespaced-json && ng2-translate-extract --dir ./src --output ./src/assets/i18n/es.json --clean --sort --format namespaced-json && ng2-translate-extract --dir ./src --output ./src/assets/i18n/fr.json --clean --sort --format namespaced-json  && ng2-translate-extract --dir ./src --output ./src/assets/i18n/it.json --clean --sort --format namespaced-json",
    "e2e": "ng e2e"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~7.2.0",
