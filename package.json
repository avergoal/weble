        "PHOTOLIBRARY_ADD_USAGE_DESCRIPTION": "This app needs write-access to photo libraryoy",
        "PHOTOLIBRARY_USAGE_DESCRIPTION": "This app needs read/write-access photo library access"
      },
      "cordova-plugin-deeplinks": {},
      "cordova-plugin-crypto-file": {},
      "cordova-plugin-inappbrowser": {},
